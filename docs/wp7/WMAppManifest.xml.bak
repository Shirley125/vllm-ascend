<?xml version="1.0" encoding="utf-8"?>
<Deployment xmlns="http://schemas.microsoft.com/windowsphone/2009/deployment" AppPlatformVersion="7.1">
  <App xmlns="" ProductID="{#app_product_id#}" Title="#app_name#" RuntimeType="Silverlight" Version="1.0.0.0" Genre="apps.normal" Author="nextapp.cn" Description="nextapp.cn" Publisher="nextapp.cn">
    <IconPath IsRelative="true" IsResource="false">ApplicationIcon.png</IconPath>
    <Capabilities>
      <Capability Name="ID_CAP_IDENTITY_DEVICE" />
      <Capability Name="ID_CAP_NETWORKING" />
      <Capability Name="ID_CAP_WEBBROWSERCOMPONENT" />
    </Capabilities>
    <Tasks>
      <DefaultTask Name="_default" NavigationPage="MainPage.xaml" />
      <ExtendedTask Name="BackgroundTask">
        <BackgroundServiceAgent Specifier="ScheduledTaskAgent" Name="NextApp.WP7.ScheduledTaskAgent_GetNewBlogs" Source="NextApp.WP7.ScheduledTaskAgent_GetNewBlogs" Type="NextApp.WP7.ScheduledTaskAgent_GetNewBlogs.ScheduledAgent" />
      </ExtendedTask>
    </Tasks>
    <Tokens>
      <PrimaryToken TokenID="NextApp.WP7Token" TaskName="_default">
        <TemplateType5>
          <BackgroundImageURI IsRelative="true" IsResource="false">Background.png</BackgroundImageURI>
          <Count>0</Count>
          <Title>#app_name#</Title>
        </TemplateType5>
      </PrimaryToken>
    </Tokens>
  </App>
</Deployment>
